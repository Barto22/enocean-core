    "analyze": [
        "--analyzers=clang-tidy",
        "--enable",
        "sensitive",
        "--enable",
        "profile:security",
        "--enable",
        "profile:portability",
        "-i",
        "skip.codecheck",
        "--analyzer-config",
        "clang-tidy:cc-verbatim-args-file=clang_tidy_args.txt"
    ]
}